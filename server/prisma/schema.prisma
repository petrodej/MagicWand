generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String
  name          String
  role          String     @default("admin") // "admin" or "viewer"
  createdAt     DateTime   @default(now())
  computers     Computer[]
  sessions      Session[]
  alertRules    AlertRule[]
  alertLogs     AlertLog[]
  auditLogs     AuditLog[]
  scheduledTasks ScheduledTask[]
  scripts       Script[]
}

model Computer {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  hostname      String
  os            String
  cpuModel      String?
  ramTotalMb    Int?
  agentSecret   String        @unique
  enrollToken   String?       @unique
  enrollExpiry  DateTime?
  isOnline      Boolean       @default(false)
  lastSeen      DateTime?
  ipAddress     String?
  macAddress    String?
  agentVersion  String?
  tags          String        @default("")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  chatMessages  ChatMessage[]
  alertRules    AlertRule[]
  alertLogs     AlertLog[]
  auditLogs     AuditLog[]
  scheduledTasks ScheduledTask[]
}

model ChatMessage {
  id            String   @id @default(uuid())
  computerId    String
  computer      Computer @relation(fields: [computerId], references: [id], onDelete: Cascade)
  role          String
  content       String
  metadata      String?
  createdAt     DateTime @default(now())
}

model AlertRule {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  computerId    String?
  computer      Computer? @relation(fields: [computerId], references: [id], onDelete: Cascade)
  type          String   // "offline", "cpu", "ram", "disk"
  threshold     Float?   // percentage threshold for cpu/ram/disk
  webhookUrl    String?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model AlertLog {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  computerId    String
  computer      Computer @relation(fields: [computerId], references: [id], onDelete: Cascade)
  type          String
  message       String
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Script {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String   @default("")
  command       String
  shell         String   @default("powershell")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ScheduledTask {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  computerId    String
  computer      Computer @relation(fields: [computerId], references: [id], onDelete: Cascade)
  name          String
  command       String
  shell         String   @default("powershell")
  cronExpr      String   // cron expression e.g. "0 */6 * * *"
  enabled       Boolean  @default(true)
  lastRun       DateTime?
  lastResult    String?  // JSON: {stdout, stderr, exitCode}
  nextRun       DateTime?
  createdAt     DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  computerId    String?
  computer      Computer? @relation(fields: [computerId], references: [id], onDelete: SetNull)
  action        String   // "execute_command", "remote_session", "file_upload", "file_delete", "computer_add", "computer_delete", "alert_rule_create", etc.
  details       String?  // JSON string with extra context
  ipAddress     String?
  createdAt     DateTime @default(now())
}

model Session {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())
}
